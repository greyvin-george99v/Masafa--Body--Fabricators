{
    "version": 2,
    "framework": null,
    "functions": {
        "api/index.php": { "runtime": "vercel-php@0.6.0" }
    },
    "outputDirectory": "public",
    "installCommand": "echo 'Skipping install'",
    "buildCommand": "echo 'Skipping build'",
    "routes": [
        {
            "src": "/(css|js|images|fonts|favicon.ico)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}